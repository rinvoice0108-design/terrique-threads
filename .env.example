# ─────────────────────────────────────────────
# threads-daily-mailer 환경 설정
# 이 파일을 .env로 복사 후 실제 값으로 채우세요
#   cp .env.example .env
# ─────────────────────────────────────────────

# Gemini API 키 (무료 티어 사용 가능)
# 발급: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 발신 Gmail 계정 (필수)
# Gmail → 설정 → 보안 → 2단계 인증 ON → 앱 비밀번호 16자리 생성
EMAIL_USER=terriquead@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# 수신 이메일 (매일 포스트를 받을 주소)
EMAIL_TO=terriquead@gmail.com

# 브랜드 설정 (기본값 유지 가능)
BRAND_NAME=테리크
POST_COUNT=3
